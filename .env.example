# Copy this file to .env and customize values before running docker compose.
# docker compose will automatically load .env if present.

# PostgreSQL credentials
POSTGRES_USER=mluser
POSTGRES_PASSWORD=change_me_strong_password_here
POSTGRES_DB=mlautomation

# JWT secret — MUST be changed in production! Use a random 32+ character string.
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars

# Token expiry in minutes (default: 10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Port on host that the app will be accessible at (default: 3000)
APP_PORT=3000
